# ── Backend-only secrets ──────────────────────────────────────────────────────
# Copy this file to .env (gitignored). These values are read ONLY by apps/backend.
# NEVER put the Coasty key in any client app, bundle, or commit.

# Your Coasty API key. Use a sandbox key (sk-coasty-test-*) for development —
# sandbox keys never bill. Live keys (sk-coasty-live-*) spend real money.
COASTY_API_KEY=sk-coasty-test-000000000000000000000000000000000000000000000000

# Coasty API base. Point at the bundled mock server for fully-offline development:
#   pnpm dev:mock   (serves http://127.0.0.1:4010/v1)
# Use https://coasty.ai/v1 for the real service.
COASTY_BASE_URL=http://127.0.0.1:4010/v1

# open-cowork backend
COWORK_PORT=4000
# Public URL Coasty uses to deliver webhooks back to this backend (https in prod).
COWORK_PUBLIC_URL=http://127.0.0.1:4000
COWORK_DB_PATH=./data/cowork.sqlite
# Secret used to sign/HMAC client session tokens. 32+ random chars in production.
COWORK_SESSION_SECRET=dev-only-change-me-please-32chars!
# Server-enforced default spending cap per run, in USD cents.
COWORK_DEFAULT_BUDGET_CENTS=500

# Optional: set to 1 (with a sk-coasty-test-* key and COASTY_BASE_URL=https://coasty.ai/v1)
# to enable live sandbox smoke tests. Leave empty otherwise; tests skip cleanly.
COWORK_RUN_LIVE=
