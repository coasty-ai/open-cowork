# ── open-cowork configuration ────────────────────────────────────────────────
# Copy this file to .env (gitignored). Read ONLY by apps/backend.
# NEVER put the Coasty key in any client app, bundle, or commit.
#
# ⭐ ONE-KEY SETUP: the ONLY thing you ever need to set is COASTY_API_KEY.
#    Everything below it is optional and has a working default.
#
#    • Set COASTY_API_KEY  → the whole product talks to the real Coasty API.
#                            Use a sandbox key (sk-coasty-test-*) — it never bills.
#    • Leave it UNSET      → DEMO MODE: `pnpm dev` boots the bundled mock Coasty
#                            server and the backend uses an ephemeral sandbox key.
#                            Zero account, zero spend, full product end-to-end.

# Your Coasty API key (sandbox keys start with sk-coasty-test- and never bill).
# Create one at https://coasty.ai/developers/keys
COASTY_API_KEY=

# ── Optional overrides (sensible defaults; you can delete all of these) ───────

# Coasty API base. Auto-resolves: the bundled mock in demo mode, else the real
# API. Override to pin one explicitly.
#   real:  https://coasty.ai/v1
#   mock:  http://127.0.0.1:4010/v1
# COASTY_BASE_URL=

# Backend bind + port.
# COWORK_PORT=4000
# COWORK_HOST=127.0.0.1

# Public URL Coasty uses to deliver webhooks back to this backend (https in prod).
# COWORK_PUBLIC_URL=http://127.0.0.1:4000

# SQLite path (':memory:' for ephemeral).
# COWORK_DB_PATH=./data/cowork.sqlite

# Secret backing client session tokens. Auto-generated if unset (tokens then do
# not survive a restart). Set a stable 32+ char value in production.
# COWORK_SESSION_SECRET=

# Server-enforced default per-run spending cap, in USD cents.
# COWORK_DEFAULT_BUDGET_CENTS=500

# Force the mock even with a key set (handy for offline demos).
# COWORK_USE_MOCK=1

# Opt-in live sandbox smoke tests (sk-coasty-test-* + COASTY_BASE_URL=real only).
# COWORK_RUN_LIVE=
